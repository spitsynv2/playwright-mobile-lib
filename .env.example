# Orchestrator connection. Leave all unset for local runs (iOS webkit.launch /
# Android ADB devices).
#
# Option A: one orchestrator base; the platform path is derived per run
# (iOS -> /safari, Android -> /playwright).
# PWM_ORCHESTRATOR=ws://example.com:7777
#
# Option B: explicit per-platform endpoints (these win over PWM_ORCHESTRATOR).
IOS_WS_ENDPOINT=
ANDROID_WS_ENDPOINT=

# Optional Authorization for an orchestrator behind an auth proxy. Sent as a
# connect header on both platforms. Precedence: raw header > bearer token >
# basic user/password.
PWM_AUTH_USER=
PWM_AUTH_PASSWORD=
# PWM_AUTH_TOKEN=
# PWM_AUTH_HEADER=

# Local pre-flight: with no endpoint set, runs launch a local browser and emulate
# the capabilities.deviceName viewport (iOS -> WebKit, Android -> Chromium).
#
# Android only: to drive a real connected device over ADB instead of local
# Chromium, set a serial (or PWM_ANDROID_ADB=true).
ANDROID_SERIAL=
# PWM_ANDROID_ADB=true
ADB_SERVER_HOST=127.0.0.1
ADB_SERVER_PORT=5037
ANDROID_OMIT_DRIVER_INSTALL=false

# Connection behavior. The code fallback is 120000 ms; 180000 covers cold farm starts.
# PWM_* are the cross-platform names; IOS_* variants remain as back-compat aliases.
PWM_CONNECT_TIMEOUT_MS=180000
PWM_CLIENT_ID=
PLAYWRIGHT_SLOW_MO_MS=0

# Optional Zebrunner session, artifact, and structured-action reporting.
REPORTING_ENABLED=false
