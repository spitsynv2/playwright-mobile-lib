# Remote iOS bridge/orchestrator connection. Leave unset for local webkit.launch().
IOS_WS_ENDPOINT=

# Connection behavior. The code fallback is 120000 ms; 180000 covers cold farm starts.
IOS_CONNECT_TIMEOUT_MS=180000
IOS_CLIENT_ID=
PLAYWRIGHT_SLOW_MO_MS=0

# Optional Zebrunner session, artifact, and structured-action reporting.
REPORTING_ENABLED=false
